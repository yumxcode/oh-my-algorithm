{
  "_comment": "Canonical experiment config schema. All fields required unless marked [optional].",
  "_schema_version": "1.0",

  "exp_id": "exp-YYYYMMDD-001",
  "phase": "train",
  "design_ref": "design-YYYYMMDD-001",
  "tune_ref": "[optional] tune-YYYYMMDD-001",
  "started_at": "[ISO 8601 timestamp — written before training begins]",

  "seeds": [42, 123, 456],

  "hyperparameters": {
    "learning_rate": 3e-4,
    "batch_size": 128,
    "epochs": 50,
    "optimizer": "AdamW",
    "weight_decay": 1e-2,
    "lr_schedule": "cosine_warmup",
    "warmup_steps": 500,
    "warmup_ratio": "[optional — use either warmup_steps or warmup_ratio]",
    "gradient_clip_norm": 1.0,
    "dropout": 0.1,
    "label_smoothing": "[optional] 0.0"
  },

  "model": {
    "architecture": "[e.g. transformer-encoder, resnet50, xgboost]",
    "num_parameters": "[filled in by $implement after model init]",
    "checkpoint_save_every_n_steps": 500,
    "save_best_by": "[metric name from requirements.md]"
  },

  "data": {
    "version": "[hash or description]",
    "split": "80/10/10",
    "train_path": "[path or description]",
    "val_path": "[path or description]",
    "test_path": "[path — NOT loaded during train or tune]",
    "num_workers": 4,
    "worker_seed_base": 0
  },

  "environment": {
    "framework": "[pytorch / jax / tensorflow] [version]",
    "cuda": "[version or cpu]",
    "mixed_precision": false,
    "deterministic_mode": true
  },

  "budget": {
    "max_gpu_hours": "[from requirements.md]",
    "estimated_gpu_hours": "[pre-run estimate]"
  }
}
